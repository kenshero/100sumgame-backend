# Development Environment Variables
# This file is loaded by docker-compose for local development

# Server
PORT=8080
ENVIRONMENT=development

# Database (matches docker-compose db service)
DATABASE_URL=postgres://postgres:postgres@db:5432/sum100game?sslmode=disable

# Gemini AI (get your key from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
